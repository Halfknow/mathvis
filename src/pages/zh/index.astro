---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { CourseCard } from '../../components/learning/CourseCard';
import { Button } from '../../components/ui/Button';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('zh');

const courses = [
  {
    href: '/zh/courses/linear-algebra',
    title: t('course.linearAlgebra.title'),
    description: t('course.linearAlgebra.description'),
    symbol: 'λ',
    lessonCount: 24,
    estimatedHours: 18,
    progressPct: 35,
    difficulty: 'Beginner' as const,
  },
  {
    href: '/zh/courses/calculus',
    title: t('course.calculus.title'),
    description: t('course.calculus.description'),
    symbol: '∫',
    lessonCount: 32,
    estimatedHours: 26,
    difficulty: 'Beginner' as const,
  },
  {
    href: '/zh/courses/probability',
    title: t('course.probability.title'),
    description: t('course.probability.description'),
    symbol: 'P',
    lessonCount: 19,
    estimatedHours: 14,
    difficulty: 'Intermediate' as const,
  },
];
---

<BaseLayout title="通过动画学习数学" lang="zh">
  <main>
    <section class="mx-auto max-w-7xl px-6 pt-24 pb-20 lg:pt-32">
      <div class="max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-wider text-accent">
          概率论 · 线性代数 · 微积分
        </p>
        <h1 class="mt-4 font-serif text-display font-semibold tracking-tight text-ink leading-[1.05]">
          数学，<span class="italic">看得见。</span>
        </h1>
        <p class="mt-6 max-w-2xl font-serif text-body-lg text-ink-muted leading-relaxed">
          结构化的课程体系，每个概念都配有可暂停、可拖拽、可回放的动画——让直觉先于公式建立。
        </p>
        <div class="mt-10 flex items-center gap-3">
          <a href="/zh/courses/linear-algebra">
            <Button variant="primary" size="lg" client:load>
              开始学习线性代数
            </Button>
          </a>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-6">
      <div class="h-px bg-rule"></div>
    </div>

    <section class="mx-auto max-w-7xl px-6 py-20">
      <div class="flex items-end justify-between">
        <div>
          <p class="font-mono text-xs uppercase tracking-wider text-ink-faint">
            三门课程
          </p>
          <h2 class="mt-2 font-serif text-h2 text-ink m-0">
            如教科书般严谨，如系列片般流畅。
          </h2>
        </div>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {courses.map((course) => (
          <CourseCard {...course} client:load />
        ))}
      </div>
    </section>

    <section class="bg-surface-1 border-y border-rule py-20">
      <div class="mx-auto max-w-7xl px-6">
        <p class="font-mono text-xs uppercase tracking-wider text-ink-faint">
          学习方式
        </p>
        <h2 class="mt-2 font-serif text-h2 text-ink m-0 max-w-2xl">
          三层递进式讲解，贯穿一整课。
        </h2>

        <div class="mt-16 grid gap-12 md:grid-cols-3">
          <div>
            <div class="grid h-12 w-12 place-items-center rounded-md bg-paper-elevated border border-rule font-serif text-h3 text-accent">1</div>
            <h3 class="mt-6 font-serif text-h3 text-ink m-0">观看</h3>
            <p class="mt-3 font-sans text-body text-ink-muted leading-relaxed">
              一段简短的 Manim 动画以几何方式引入概念——就像一位优秀的老师在黑板上画出来那样。
            </p>
          </div>
          <div>
            <div class="grid h-12 w-12 place-items-center rounded-md bg-paper-elevated border border-rule font-serif text-h3 text-accent">2</div>
            <h3 class="mt-6 font-serif text-h3 text-ink m-0">操作</h3>
            <p class="mt-3 font-sans text-body text-ink-muted leading-relaxed">
              交互式组件让你改变参数并实时观察变化。拖动特征向量、拉伸概率分布。
            </p>
          </div>
          <div>
            <div class="grid h-12 w-12 place-items-center rounded-md bg-paper-elevated border border-rule font-serif text-h3 text-accent">3</div>
            <h3 class="mt-6 font-serif text-h3 text-ink m-0">验证</h3>
            <p class="mt-3 font-sans text-body text-ink-muted leading-relaxed">
              只有当几何直觉建立之后，我们才引入形式化定义——加上少量练习来确认你已经掌握。
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-3xl px-6 py-24 text-center">
      <p class="font-serif italic text-h3 text-ink-muted leading-snug">
        "看不见的东西，我们无法真正理解。数学也不例外。"
      </p>
      <p class="mt-3 font-sans text-sm text-ink-faint">—— 本站的核心信念</p>
      <div class="mt-10">
        <a href="/zh/courses/linear-algebra">
          <Button variant="primary" size="lg" client:load>选择课程</Button>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

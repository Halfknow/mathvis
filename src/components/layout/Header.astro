---
const navItems = [
  { href: '/courses/linear-algebra', label: 'Linear Algebra' },
  { href: '/courses/calculus', label: 'Calculus' },
  { href: '/courses/probability', label: 'Probability' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-rule bg-paper/85 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-6">
    <!-- Logo / wordmark -->
    <a href="/" class="group flex items-center gap-2 no-underline">
      <span class="grid h-7 w-7 place-items-center rounded-md bg-ink text-paper-elevated transition-colors duration-base ease-smooth group-hover:bg-accent">
        <span class="font-serif text-base font-semibold leading-none">∫</span>
      </span>
      <span class="font-serif text-lg font-semibold tracking-tight text-ink">
        MathViz
      </span>
    </a>

    <!-- Primary nav -->
    <nav class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-md px-3 py-1.5 font-sans text-sm transition-colors duration-fast ease-smooth no-underline',
            currentPath.startsWith(item.href)
              ? 'text-ink bg-surface-1'
              : 'text-ink-muted hover:text-ink hover:bg-surface-1',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <button
        type="button"
        aria-label="Search"
        class="grid h-9 w-9 place-items-center rounded-md text-ink-muted transition-colors duration-fast ease-smooth hover:bg-surface-1 hover:text-ink"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </button>
      <button
        type="button"
        id="theme-toggle"
        aria-label="Toggle theme"
        class="grid h-9 w-9 place-items-center rounded-md text-ink-muted transition-colors duration-fast ease-smooth hover:bg-surface-1 hover:text-ink"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  const stored = localStorage.getItem('theme');
  if (stored) document.documentElement.setAttribute('data-theme', stored);
</script>

---
import { useTranslations, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang } = Astro.props;
const locale = lang ?? 'en';
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-rule">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-12 text-sm text-ink-faint md:flex-row md:items-center md:justify-between">
    <p>
      <span class="font-serif text-ink">MathViz</span> · {t('footer.description')}
    </p>
    <nav class="flex gap-6">
      <a href={getLocalizedPath('/courses/linear-algebra', locale)} class="text-ink-muted hover:text-ink no-underline">{t('nav.linearAlgebra')}</a>
      <a href={getLocalizedPath('/courses/calculus', locale)} class="text-ink-muted hover:text-ink no-underline">{t('nav.calculus')}</a>
      <a href={getLocalizedPath('/courses/probability', locale)} class="text-ink-muted hover:text-ink no-underline">{t('nav.probability')}</a>
    </nav>
    <p class="font-mono text-xs">&copy; {year} &middot; MIT</p>
  </div>
</footer>

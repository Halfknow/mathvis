---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { CourseCard } from '../components/learning/CourseCard';
import { Button } from '../components/ui/Button';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('en');

const courses = [
  {
    href: '/courses/linear-algebra',
    title: t('course.linearAlgebra.title'),
    description: t('course.linearAlgebra.description'),
    symbol: 'λ',
    lessonCount: 24,
    estimatedHours: 18,
    progressPct: 35,
    difficulty: 'Beginner' as const,
  },
  {
    href: '/courses/calculus',
    title: t('course.calculus.title'),
    description: t('course.calculus.description'),
    symbol: '∫',
    lessonCount: 32,
    estimatedHours: 26,
    difficulty: 'Beginner' as const,
  },
  {
    href: '/courses/probability',
    title: t('course.probability.title'),
    description: t('course.probability.description'),
    symbol: 'P',
    lessonCount: 19,
    estimatedHours: 14,
    difficulty: 'Intermediate' as const,
  },
];
---

<BaseLayout title="Learn math through animation" lang="en">
  <main>
    <section class="mx-auto max-w-7xl px-6 pt-24 pb-20 lg:pt-32">
      <div class="max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-wider text-accent">
          Probability · Linear algebra · Calculus
        </p>
        <h1 class="mt-4 font-serif text-display font-semibold tracking-tight text-ink leading-[1.05]">
          Mathematics, <span class="italic">made visible.</span>
        </h1>
        <p class="mt-6 max-w-2xl font-serif text-body-lg text-ink-muted leading-relaxed">
          A structured course system where every concept is paired with an animation you can scrub, pause,
          and play with — so the intuition lands before the formalism does.
        </p>
        <div class="mt-10 flex items-center gap-3">
          <a href="/courses/linear-algebra">
            <Button variant="primary" size="lg" client:load>
              Start with Linear Algebra
            </Button>
          </a>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-6">
      <div class="h-px bg-rule"></div>
    </div>

    <section class="mx-auto max-w-7xl px-6 py-20">
      <div class="flex items-end justify-between">
        <div>
          <p class="font-mono text-xs uppercase tracking-wider text-ink-faint">
            Three courses
          </p>
          <h2 class="mt-2 font-serif text-h2 text-ink m-0">
            Built like a textbook, paced like a series.
          </h2>
        </div>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {courses.map((course) => (
          <CourseCard {...course} client:load />
        ))}
      </div>
    </section>

    <section class="bg-surface-1 border-y border-rule py-20">
      <div class="mx-auto max-w-7xl px-6">
        <p class="font-mono text-xs uppercase tracking-wider text-ink-faint">
          How it works
        </p>
        <h2 class="mt-2 font-serif text-h2 text-ink m-0 max-w-2xl">
          Three layers of explanation, one continuous lesson.
        </h2>

        <div class="mt-16 grid gap-12 md:grid-cols-3">
          <div>
            <div class="grid h-12 w-12 place-items-center rounded-md bg-paper-elevated border border-rule font-serif text-h3 text-accent">1</div>
            <h3 class="mt-6 font-serif text-h3 text-ink m-0">Watch</h3>
            <p class="mt-3 font-sans text-body text-ink-muted leading-relaxed">
              A short, narrated Manim animation introduces the concept geometrically — the way a great teacher would draw it on a chalkboard.
            </p>
          </div>
          <div>
            <div class="grid h-12 w-12 place-items-center rounded-md bg-paper-elevated border border-rule font-serif text-h3 text-accent">2</div>
            <h3 class="mt-6 font-serif text-h3 text-ink m-0">Play</h3>
            <p class="mt-3 font-sans text-body text-ink-muted leading-relaxed">
              An interactive widget lets you change parameters and watch the behavior shift in real time. Drag the eigenvector. Stretch the distribution.
            </p>
          </div>
          <div>
            <div class="grid h-12 w-12 place-items-center rounded-md bg-paper-elevated border border-rule font-serif text-h3 text-accent">3</div>
            <h3 class="mt-6 font-serif text-h3 text-ink m-0">Prove</h3>
            <p class="mt-3 font-sans text-body text-ink-muted leading-relaxed">
              Only after the geometry feels obvious do we introduce the formal definition — and a small set of exercises to verify the idea has stuck.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-3xl px-6 py-24 text-center">
      <p class="font-serif italic text-h3 text-ink-muted leading-snug">
        "What we cannot see, we cannot really know. Mathematics is no exception."
      </p>
      <p class="mt-3 font-sans text-sm text-ink-faint">— the entire premise of this site</p>
      <div class="mt-10">
        <a href="/courses/linear-algebra">
          <Button variant="primary" size="lg" client:load>Choose a course</Button>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

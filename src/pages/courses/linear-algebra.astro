---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { ProgressBar } from '../../components/ui/ProgressBar';
import { Badge } from '../../components/ui/Badge';

const course = {
  title: 'Linear Algebra',
  symbol: 'λ',
  description:
    'Twenty-four lessons spanning vectors and vector spaces, linear transformations, eigentheory, and applications. Built around the conviction that geometry is primary and coordinates are derivative.',
  difficulty: 'Beginner',
  lessonCount: 24,
  estimatedHours: 18,
  progressPct: 35,
};

const modules = [
  {
    title: 'Vector Spaces',
    blurb: 'Arrows, addition, scaling — the foundation.',
    lessons: [
      { title: 'Vectors as arrows', duration: 14, completed: true },
      { title: 'Vector addition, geometrically', duration: 12, completed: true },
      { title: 'Scalar multiplication', duration: 9, completed: true },
      { title: 'Linear combinations', duration: 16, completed: false },
      { title: 'Spans', duration: 18, completed: false },
      { title: 'Basis and dimension', duration: 22, completed: false },
    ],
  },
  {
    title: 'Linear Transformations',
    blurb: 'Matrices, finally, as a way to write down transformations.',
    lessons: [
      { title: 'Functions on vectors', duration: 11, completed: false },
      { title: 'What linearity means', duration: 14, completed: false },
      { title: 'Matrices as transformations', duration: 19, completed: false },
      { title: 'Matrix multiplication, composed', duration: 17, completed: false },
    ],
  },
  {
    title: 'Determinant & Inverse',
    blurb: 'How transformations stretch space.',
    lessons: [
      { title: 'The determinant, geometrically', duration: 16, completed: false },
      { title: 'When transformations are reversible', duration: 13, completed: false },
      { title: 'Computing inverses', duration: 15, completed: false },
    ],
  },
  {
    title: 'Eigentheory',
    blurb: 'The directions a transformation leaves alone.',
    lessons: [
      { title: 'Eigenvectors as fixed directions', duration: 18, completed: false },
      { title: 'Eigenvalues', duration: 14, completed: false },
      { title: 'Diagonalization', duration: 21, completed: false },
    ],
  },
];
---

<BaseLayout title={course.title}>
  <main class="mx-auto max-w-5xl px-6 py-16">
    <!-- Header -->
    <header class="grid gap-10 md:grid-cols-[160px_1fr] md:items-start">
      <div class="grid h-40 w-40 place-items-center rounded-md border border-rule bg-surface-1">
        <span class="font-serif text-[120px] leading-none text-ink">{course.symbol}</span>
      </div>
      <div>
        <p class="font-mono text-xs uppercase tracking-wider text-ink-faint">Course</p>
        <h1 class="mt-2 font-serif text-h1 text-ink m-0">{course.title}</h1>
        <p class="mt-4 font-serif text-body-lg text-ink-muted leading-relaxed max-w-2xl">
          {course.description}
        </p>
        <div class="mt-6 flex items-center gap-3">
          <Badge variant="neutral" client:load>{course.difficulty}</Badge>
          <span class="font-mono text-sm text-ink-faint">
            {course.lessonCount} lessons · ~{course.estimatedHours}h
          </span>
        </div>
      </div>
    </header>

    <!-- Progress -->
    <section class="mt-12">
      <div class="flex items-center justify-between">
        <p class="font-sans text-sm font-medium text-ink">Your progress</p>
        <span class="font-mono text-xs text-ink-muted">3 of {course.lessonCount} complete</span>
      </div>
      <div class="mt-2">
        <ProgressBar value={course.progressPct} client:load />
      </div>
    </section>

    <!-- Modules -->
    <section class="mt-16 space-y-12">
      {modules.map((mod, mIdx) => (
        <div>
          <header class="flex items-baseline justify-between border-b border-rule pb-3">
            <div>
              <p class="font-mono text-xs uppercase tracking-wider text-ink-faint">
                Module {mIdx + 1}
              </p>
              <h2 class="mt-1 font-serif text-h2 text-ink m-0">{mod.title}</h2>
            </div>
            <p class="hidden font-sans text-sm italic text-ink-muted md:block">{mod.blurb}</p>
          </header>

          <ol class="mt-4 divide-y divide-rule">
            {mod.lessons.map((lesson, lIdx) => (
              <li>
                <a
                  href={`/courses/linear-algebra/${mod.title.toLowerCase().replace(/\s+/g, '-')}/${lesson.title.toLowerCase().replace(/\s+/g, '-').replace(/,/g, '')}`}
                  class="group flex items-center gap-5 py-4 no-underline transition-colors duration-fast ease-smooth hover:bg-surface-1 -mx-2 px-2 rounded-md"
                >
                  <span class:list={[
                    'grid h-7 w-7 shrink-0 place-items-center rounded-pill font-mono text-xs',
                    lesson.completed
                      ? 'bg-vector-green text-paper-elevated'
                      : 'border border-rule text-ink-faint',
                  ]}>
                    {lesson.completed ? (
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    ) : (
                      <span>{lIdx + 1}</span>
                    )}
                  </span>
                  <span class="flex-1 font-serif text-body-lg text-ink group-hover:text-accent transition-colors duration-fast">
                    {lesson.title}
                  </span>
                  <span class="font-mono text-xs text-ink-faint">{lesson.duration} min</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </section>
  </main>
</BaseLayout>
